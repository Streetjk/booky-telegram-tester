# Get API_ID and API_HASH from https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# The bot to test (username without @)
BOT_USERNAME=Data33catbot

# TELEGRAM_PHONE is not required — login uses QR code instead.
# On first run a QR code prints in the terminal.
# Scan it with Telegram Desktop: Settings → Devices → Link Desktop Device

# Redis — used to flush Hiro's session between personas (prevents context bleed)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# Space-separated UUIDs of the test account's user rows in the bookkeeper DB
HIRO_USER_IDS=
